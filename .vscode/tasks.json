{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Hugo Server",
      "type": "shell",
      "command": "hugo server --bind 127.0.0.1 -p 1313",
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".",
              "file": 1,
              "location": 2,
              "message": 3
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "Watching for changes",
            "endsPattern": "Web Server is available"
          }
        }
      ],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
